# uma-tally-tool settings.
# Copy this to .env next to the uma-tally-tool binary.
# Lines starting with # are comments. Change the values below, then run:
#   python -m uma_tally_tool --env .env

# Your numeric uma.moe circle id. This is required unless you pass --circle-id.
CIRCLE_ID=0

# Monthly fan quota each member is expected to hit.
# The app derives the daily pace from this based on the current month length.
MONTHLY_QUOTA=60000000

# Daily fan gains below this amount count in the "Days < N" column.
LOW_DAY_THRESHOLD=500000

# Folder where report PNGs are saved. The app creates it if it does not exist.
# Only used when SAVE_OUTPUT=true or when no DISCORD_WEBHOOK is configured.
OUTPUT_DIR=out

# Whether to keep a local PNG after rendering.
# false: render a temporary PNG for Discord upload, then delete it.
# true: also save a copy in OUTPUT_DIR.
SAVE_OUTPUT=false

# Header/table font family: uma uses the game-style font, mplus uses a rounded fallback.
FONT=uma

# Mid-month joiner handling.
# strict: every member is held to the full monthly quota.
# prorated: joiners are only measured against the days they have been in the club.
JOINER_QUOTA=strict

# Snapshot cutoff mode.
# complete: ignore the current in-progress game day.
# live: include the current in-progress game day.
TALLY=complete

# Quota display style.
# numbers: keep Expected, Total Fans, and Behind By columns.
# bar: replace those three columns with one monthly quota progress bar.
EXPECTED_FANS_STYLE=numbers

# Status colors used by both progress bars and Done/Yes/No badges.
# Values can be #RRGGBB, RRGGBB, or comma-separated RGB like 91,190,255.
ON_PACE_COLOR=#5BBEFF
FINISHED_COLOR=#77DD8B
OFF_PACE_COLOR=#EB5252

# Column toggles. Accepted values: true/false, yes/no, on/off, show/hide.
# Shows or hides the average fans per day column.
SHOW_DAILY_AVG=true

# Shows or hides the Done/Yes/No pace badge column.
SHOW_ON_PACE=true

# Shows or hides the fans-per-day needed from now until month end.
SHOW_NEEDED_PER_DAY=true

# Shows or hides the count of days below LOW_DAY_THRESHOLD.
SHOW_DAYS_BELOW_THRESHOLD=true

# Shows or hides the latest day gain column, labelled Day X in the report.
SHOW_LATEST_DAY=true

# Pins the club leader first when uma.moe provides leader_name.
PIN_LEADER=false

# Shows a small leader label in the rank column when uma.moe provides leader_name.
HIGHLIGHT_LEADER=false

# Optional local logo path shown beside the club name. Leave blank for no logo.
CLUB_LOGO=

# Discord webhook. Leave blank for local testing without posting.
DISCORD_WEBHOOK=

# uma.moe API key. For GitHub Actions, store this as the UMA_API_KEY secret.
UMA_API_KEY=
